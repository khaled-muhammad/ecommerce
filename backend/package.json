{
  "name": "roxy-backend",
  "version": "1.0.0",
  "description": "Roxy ecommerce API",
  "license": "UNLICENSED",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "test": "vitest run",
    "lint": "tsc --noEmit",
    "seed": "tsx src/db/seed.ts",

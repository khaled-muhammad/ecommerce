# Environment
NODE_ENV=development
PORT=4000

# CORS
CORS_ORIGINS=http://localhost:5173

# SPA origin (checkout redirect URLs)
FRONTEND_URL=http://localhost:5173

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/roxy
# Product catalog sync (npm run products:export / products:import): export uses this URL locally;
# import on deployment needs DATABASE_URL pointed at the deploy DB (env var; production does not load .env automatically).

# Auth
JWT_SECRET=change-me-in-production
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:4000/api/v1/auth/google/callback

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=

# Redis (optional - rate limiting, sessions, cache)
REDIS_URL=redis://localhost:6379

# Storage (admin catalog image upload: POST /api/v1/admin/catalog/upload)
# Priority: S3 (bucket + keys) → Hack Club CDN (HACKCLUB_CDN_BEARER / HACKCLUB_CDN_KEY) → local disk (backend/uploads/, served at /uploads).
S3_ENDPOINT=
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=us-east-1
S3_PUBLIC_BASE_URL=
HACKCLUB_CDN_BEARER=
HACKCLUB_CDN_KEY=
# Optional: public base for local disk URLs (when S3 + Hack Club unset). If empty, taken from Host on upload.
UPLOAD_PUBLIC_BASE_URL=